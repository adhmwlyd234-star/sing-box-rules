{
  "log": {
    "loglevel": "warning"
  },
  "dns": {
    "servers": [
      "1.1.1.1",
      "8.8.8.8"
    ],
    "tag": "dns_inbound"
  },
  "inbounds": [
    {
      "port": 10808,
      "protocol": "socks",
      "settings": {
        "auth": "noauth"
      },
      "tag": "socks-in"
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      },
      "streamSettings": {
        "sockopt": {
          "fragment": {
            "packets": "tlshello",
            "length": "10-20",
            "interval": "5-10"
          }
        }
      },
      "tag": "direct-fragment"
    },
    {
      "protocol": "blackhole",
      "settings": {
        "response": {
          "type": "none"
        }
      },
      "tag": "blackhole-drop"
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "domain": [
          "domain:tencent.com",
          "domain:pubgmobile.com",
          "domain:crashsight.com",
          "keyword:telemetry",
          "keyword:analytics",
          "keyword:log-upload"
        ],
        "outboundTag": "blackhole-drop"
      },
      {
        "type": "field",
        "ip": [
          "43.128.0.0/16",
          "49.51.0.0/16",
          "119.28.0.0/16"
        ],
        "outboundTag": "blackhole-drop"
      },
      {
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "direct-fragment"
      }
    ]
  }
}
